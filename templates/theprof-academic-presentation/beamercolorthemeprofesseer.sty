% =============================================================================
% TheProfesseer — Beamer color theme
% Brand: Deep Crimson #7B0925. Renamed from the original org theme; values are
% unchanged so existing decks keep their look.
% =============================================================================
\mode<presentation>

\definecolor{profCrimson}{rgb}{0.4823529,0.0352941,0.1450980}  % #7B0925
\definecolor{profOffwhite}{rgb}{0.9490196,0.9568627,0.9450980} % near-white tint
\definecolor{profInk}{rgb}{0.1098039,0.1098039,0.1098039}      % near-black

\setbeamercolor{section in toc}{fg=black,bg=white}
\setbeamercolor{alerted text}{fg=profCrimson!80!gray}
\setbeamercolor*{palette primary}{fg=profCrimson,bg=profOffwhite}
\setbeamercolor*{palette secondary}{fg=profCrimson!70!black,bg=gray!15!white}
\setbeamercolor*{palette tertiary}{bg=profCrimson!80!black,fg=gray!10!white}
\setbeamercolor*{palette quaternary}{fg=profCrimson,bg=gray!5!white}

\setbeamercolor*{sidebar}{fg=profCrimson,bg=profOffwhite}

\setbeamercolor*{palette sidebar primary}{fg=profCrimson!10!black}
\setbeamercolor*{palette sidebar secondary}{fg=white}
\setbeamercolor*{palette sidebar tertiary}{fg=profCrimson!50!black}
\setbeamercolor*{palette sidebar quaternary}{fg=gray!10!white}

\setbeamercolor{titlelike}{parent=palette primary,fg=profCrimson}
\setbeamercolor{frametitle}{bg=profOffwhite}
\setbeamercolor{frametitle right}{bg=gray!60!white}

\setbeamercolor*{separation line}{}
\setbeamercolor*{fine separation line}{}

\mode
<all>
